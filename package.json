{
  "name": "silvina_dev",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write \"**/*.{js,jsx,scss,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,scss,json,md}\""
  },
  "dependencies": {
    "next": "16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sass": "1.68"
  },
  "devDependencies": {
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3"
  },
  "lint-staged": {
    "*.{js,jsx}": [
      "next lint",
      "prettier --write"
    ],
    "*.{scss,css}": "prettier --write",
    "*.json": "prettier --write",
    "*.md": "prettier --write"
  }
}
